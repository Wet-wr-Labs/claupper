# For details & more options, see documentation/AppManifests.md in firmware repo
#
# Two build targets from one codebase:
#   claude_remote_usb — works on stock firmware (App Catalog)
#   claude_remote_ble — works on Momentum/Unleashed (wireless)

App(
    appid="claude_remote_usb",
    name="Agentic Remote USB",
    apptype=FlipperAppType.EXTERNAL,
    entry_point="claude_remote_usb_app",
    requires=["gui"],
    stack_size=4 * 1024,
    fap_category="USB",
    fap_version="0.27",
    fap_icon="claude_remote.png",
    fap_description="One-handed USB remote for AI coding agents (Claude Code). 5-button D-pad control, macros, offline manual + quiz.",
    fap_author="Kasen Sansonetti",
    fap_icon_assets="images",
    cdefines=["HID_TRANSPORT_USB"],
)

App(
    appid="claude_remote_ble",
    name="Agentic Remote",
    apptype=FlipperAppType.EXTERNAL,
    entry_point="claude_remote_ble_app",
    requires=["gui", "bt"],
    stack_size=4 * 1024,
    fap_category="Bluetooth",
    fap_version="0.27",
    fap_icon="claude_remote.png",
    fap_description="One-handed Bluetooth remote for AI coding agents (Claude Code). 5-button D-pad control, macros, offline manual + quiz.",
    fap_author="Kasen Sansonetti",
    fap_icon_assets="images",
    cdefines=["HID_TRANSPORT_BLE"],
    fap_libs=["ble_profile"],
)
